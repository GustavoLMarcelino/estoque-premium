# Conexão com o banco MySQL (Prisma)
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="mysql://user:password@localhost:3306/estoque_premium"

# Segredo usado para assinar os tokens JWT
JWT_SECRET="troque-por-um-segredo-forte"

# Porta da API (opcional, padrão 3000)
PORT=3000

# Usuário admin padrão criado pelo seed (npm run seed)
ADMIN_EMAIL="gustavoavomarcelino@gmail.com"
ADMIN_PASSWORD="123456789"
