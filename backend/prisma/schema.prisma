// LOCAL DEV SCHEMA (SQLite).
// O schema de produção (MySQL/RDS) está preservado em schema.mysql.prisma.
// Diferenças para SQLite: sem tipos nativos @db.*, e os enums viram String.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model estoque {
  id               Int             @id @default(autoincrement())
  produto          String
  modelo           String
  custo            Decimal
  valor_venda      Decimal
  percentual_lucro Decimal?
  qtd_minima       Int
  garantia         String?
  qtd_inicial      Int
  entradas         Int?            @default(0)
  saidas           Int?            @default(0)
  em_estoque       Int?
  garantias        garantias[]
  movimentacoes    movimentacoes[]
}

model movimentacoes {
  id                Int       @id @default(autoincrement())
  produto_id        Int
  garantia_id       Int?
  tipo              String // ENTRADA | SAIDA
  quantidade        Int
  valor_final       Decimal
  motivo            String?
  vendedor          String? // vendedor responsável (saídas)
  data_movimentacao DateTime? @default(now())
  user_id           Int?
  created_by        String? // nome/email do usuário no momento da criação
  estoque           estoque   @relation(fields: [produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([produto_id], map: "fk_produto")
  @@index([garantia_id], map: "idx_mov_garantia")
  @@index([motivo], map: "idx_mov_motivo")
}

model garantias {
  id                 Int       @id @default(autoincrement())
  cliente_nome       String
  cliente_documento  String
  cliente_telefone   String
  cliente_endereco   String
  produto_codigo     String
  produto_descricao  String
  estoque_id         Int?
  data_abertura      DateTime  @default(now())
  data_limite        DateTime?
  data_contato       DateTime?
  data_compra        DateTime?
  status             String    @default("ABERTA") // ABERTA | EM_ANALISE | APROVADA | REPROVADA | FINALIZADA
  descricao_problema String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now())
  estoque            estoque?  @relation(fields: [estoque_id], references: [id])

  @@index([estoque_id], map: "fk_garantias_estoque")
  @@index([data_limite], map: "idx_garantias_data_limite")
}

model user {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String // hash
  role       String   @default("user")
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model estoque_som {
  id               Int                 @id @default(autoincrement())
  produto          String
  modelo           String
  custo            Decimal
  valor_venda      Decimal
  percentual_lucro Decimal?
  qtd_minima       Int
  garantia         String?
  qtd_inicial      Int
  entradas         Int?                @default(0)
  saidas           Int?                @default(0)
  em_estoque       Int?
  created_at       DateTime?
  updated_at       DateTime?
  movimentacoes    movimentacoes_som[]

  @@map("estoque_som")
}

model movimentacoes_som {
  id                Int         @id @default(autoincrement())
  produto_id        Int
  garantia_id       Int?
  tipo              String // ENTRADA | SAIDA
  quantidade        Int
  valor_final       Decimal
  motivo            String?
  data_movimentacao DateTime?   @default(now())
  user_id           Int?
  created_by        String? // nome/email do usuário no momento da criação
  estoque           estoque_som @relation(fields: [produto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([produto_id], map: "idx_mov_som_produto")
  @@index([garantia_id], map: "idx_mov_som_garantia")
  @@index([motivo], map: "idx_mov_som_motivo")
  @@map("movimentacoes_som")
}

model conferencia_estoque {
  id            Int                @id @default(autoincrement())
  linha         String // BATERIAS | SOM
  status        String             @default("EM_ANDAMENTO") // EM_ANDAMENTO | FINALIZADA
  user_id       Int
  created_by    String
  created_at    DateTime           @default(now())
  finalizada_at DateTime?
  itens         conferencia_item[]

  @@index([linha], map: "idx_conf_linha")
  @@index([status], map: "idx_conf_status")
  @@index([user_id], map: "idx_conf_user")
}

model conferencia_item {
  id             Int                 @id @default(autoincrement())
  conferencia_id Int
  produto_id     Int
  linha          String // BATERIAS | SOM
  qtd_sistema    Int
  conferido      Boolean             @default(false)
  conferido_at   DateTime?
  conferencia    conferencia_estoque @relation(fields: [conferencia_id], references: [id], onDelete: Cascade)

  @@index([conferencia_id], map: "idx_conf_item_conferencia")
  @@index([produto_id], map: "idx_conf_item_produto")
}
